# Meta App credentials from developers.facebook.com
META_APP_ID=
META_APP_SECRET=

# Facebook Login Configuration ID for Embedded Signup
# Create at: https://developers.facebook.com/apps/{app-id}/facebook-login/configuration/
FB_CONFIG_ID=

# Webhook verification token (you choose this, must match Meta webhook config)
WHATSAPP_VERIFY_TOKEN=pulse_whatsapp_verify
